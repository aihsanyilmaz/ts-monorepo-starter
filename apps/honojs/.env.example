# Server port
PORT=3001

# Environment
NODE_ENV=development

# Database driver: sqlite | pg (default: sqlite)
DB_DRIVER=sqlite

# Database connection string
# SQLite: file path (relative to app root)
DATABASE_URL=./data/dev.db
# PostgreSQL: uncomment below and set DB_DRIVER=pg
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monorepo_dev
