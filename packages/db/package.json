    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "catalog:",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/better-sqlite3": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
